# ===== shion-ai 環境変数 =====
# このファイルを .env にコピーして値を設定する(.env はコミットしない)

# Web UI のログインパスワード(必ず変更すること)
SHION_PASSWORD=change-me

# セッションCookie署名・トークン暗号化用の秘密鍵(ランダムな長い文字列にする)
# 例: python -c "import secrets; print(secrets.token_hex(32))"
SHION_SECRET_KEY=change-me-to-random-hex

# --- LLM APIキー(使うものだけ設定すればよい) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
