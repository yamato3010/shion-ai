# ===== shion-ai 環境変数 =====
# このファイルを .env にコピーして値を設定する(.env はコミットしない)

# Web UI のログインパスワード(必ず変更すること)
SHION_PASSWORD=change-me

# セッションCookie署名・トークン暗号化用の秘密鍵(ランダムな長い文字列にする)
# 例: python -c "import secrets; print(secrets.token_hex(32))"
SHION_SECRET_KEY=change-me-to-random-hex

# --- LLM APIキー(使うものだけ設定すればよい) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Google連携(google_workspace プラグインを使う場合のみ) ---
# Google Cloud Console で OAuth クライアント(Webアプリ型)を作成し、
# リダイレクトURIに http://localhost:8000/api/google/oauth/callback を登録する
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Discord Bot(使う場合のみ) ---
# Discord Developer Portal で Bot を作成し、MESSAGE CONTENT INTENT を有効にする
DISCORD_BOT_TOKEN=
# あなたのDiscordユーザーID(数字)。複数人を許可する場合はカンマ区切り。
# 例: DISCORD_OWNER_ID=123456789012345678,987654321098765432
DISCORD_OWNER_ID=
# スラッシュコマンドを即時反映するサーバーID(任意)
DISCORD_GUILD_ID=
